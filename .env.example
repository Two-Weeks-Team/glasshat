# Panelyst — environment template. Copy to `.env` and fill in. NEVER commit `.env`.

# --- Google Cloud / Vertex AI / Agent Builder ---
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true
# (use Vertex AI Gemini — Gemini on AI Studio is NOT credit-eligible for the Rapid Agent hackathon)
VERTEX_GEMINI_FLASH_MODEL=gemini-2.5-flash
VERTEX_GEMINI_PRO_MODEL=gemini-2.5-pro
AGENT_BUILDER_APP_ID=

# --- Qdrant (REQUIRED — vector memory layer) ---
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=panelyst

# --- Arize (partner integration — transparent real-time fairness monitoring) ---
ARIZE_SPACE_ID=
ARIZE_API_KEY=
ARIZE_PROJECT_NAME=panelyst

# --- Repo ingestion ---
GITHUB_TOKEN=          # optional, for higher rate limits / private repos (not needed for public-repo MVP)

# --- Firestore / Firebase Auth ---
FIREBASE_PROJECT_ID=

# --- Web search (Vertex AI Grounding with Google Search) — uses GOOGLE_CLOUD_PROJECT above ---

# --- App ---
PORT=8080
NEXT_PUBLIC_DEFAULT_LOCALE=en   # en | ko
