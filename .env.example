# Panelyst — environment template. Copy to `.env` and fill in. NEVER commit `.env`.
# Verified configuration recipe (2026-05-14): see docs/gcp-setup.md for the gcloud bootstrap.

# === Identity / GCP project ===
GOOGLE_CLOUD_PROJECT=                       # e.g. panelyst-hackathon
GOOGLE_CLOUD_REGION=us-central1             # default region for Gemini 2.5 family + Cloud Run
GOOGLE_GENAI_USE_VERTEXAI=true              # always — AI Studio is NOT credit-eligible for Rapid Agent

# === Service account credentials (kept OUTSIDE the repo) ===
# Create with: gcloud iam service-accounts create panelyst-dev … (see docs/gcp-setup.md)
GOOGLE_APPLICATION_CREDENTIALS=             # absolute path to the SA JSON key, e.g. ~/.config/gcloud/panelyst-dev-sa-key.json
PANELYST_SA_EMAIL=                          # e.g. panelyst-dev@panelyst-hackathon.iam.gserviceaccount.com

# === Gemini models (3-tier) ===
# IMPORTANT: Gemini 3 family is served on the `global` endpoint ONLY (regional returns 404).
# Gemini 2.5 family is regional. Use the *_LOCATION env vars to switch endpoints per tier.
PANELYST_GEMINI_PRO=gemini-3.1-pro-preview
PANELYST_GEMINI_PRO_LOCATION=global
PANELYST_GEMINI_FLASH=gemini-3-flash-preview
PANELYST_GEMINI_FLASH_LOCATION=global
PANELYST_GEMINI_FLASH_LITE=gemini-3.1-flash-lite
PANELYST_GEMINI_FLASH_LITE_LOCATION=global

PANELYST_GEMINI_PRO_FALLBACK=gemini-2.5-pro
PANELYST_GEMINI_FLASH_FALLBACK=gemini-2.5-flash
PANELYST_GEMINI_FLASH_LITE_FALLBACK=gemini-2.5-flash-lite
PANELYST_GEMINI_FALLBACK_LOCATION=us-central1

# Token budgets — thinking models need headroom
PANELYST_PRO_MAX_OUTPUT_TOKENS=4096
PANELYST_FLASH_MAX_OUTPUT_TOKENS=2048
PANELYST_FLASH_LITE_MAX_OUTPUT_TOKENS=1024

# === Qdrant (Phase 1: local docker · Phase 4: Qdrant Cloud) ===
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=panelyst

# === Monitoring (Phase 1: Phoenix local · Phase 5: Arize hosted) ===
MONITOR_BACKEND=phoenix-local
PHOENIX_PORT=6006
ARIZE_SPACE_ID=
ARIZE_API_KEY=
ARIZE_PROJECT_NAME=panelyst

# === DocStore (Phase 1: local SQLite · Phase 3: Firestore Native) ===
DOCSTORE_BACKEND=sqlite                     # sqlite | firestore
DOCSTORE_SQLITE_PATH=./var/panelyst.db
FIRESTORE_PROJECT_ID=

# === BlobStore (Phase 1: local FS · Phase 3: Cloud Storage) ===
BLOB_BACKEND=local-fs                       # local-fs | gcs
BLOB_LOCAL_DIR=./var/uploads
GCS_UPLOADS_BUCKET=
GCS_REPORTS_BUCKET=

# === Agent runtime (Phase 1: LangGraph local · Phase 3: Agent Builder) ===
AGENT_RUNTIME=langgraph-local               # langgraph-local | agent-builder
AGENT_BUILDER_APP_ID=

# === Repo ingestion ===
GITHUB_TOKEN=

# === App ===
PORT=8080
NEXT_PUBLIC_DEFAULT_LOCALE=en               # en | ko
